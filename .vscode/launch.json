{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug STM32F446",
      "type": "cortex-debug",
      "request": "launch",
      "servertype": "openocd",
      "device": "STM32F446RE",
      "interface": "swd",
      "runToEntryPoint": "main",
      "resetOnLaunch": true,
      "executable": "${workspaceFolder}/firmware.elf",
      "configFiles": ["interface/stlink.cfg", "target/stm32f4x.cfg"],
      "showDevDebugOutput": "none"
    }
  ]
}
